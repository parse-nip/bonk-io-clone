{
  "name": "bonk-io-clone",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "mkdir -p dist && test -f dist/index.html || printf '%s\\n' '<!doctype html><html><head><title>bonk</title></head><body></body></html>' > dist/index.html && wrangler dev --port 8787",
    "dev:full": "npx concurrently -k \"npm run dev:server\" \"npm run dev\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "deploy:preview": "npm run build && wrangler deploy --temporary -c wrangler.preview.toml",
    "smoke": "node scripts/smoke.mjs",
    "test:movement": "node scripts/movement.mjs",
    "test:editor": "node scripts/editor-bugs.mjs",
    "test:tutorial": "node scripts/tutorial-physics.mjs",
    "test:multiplayer": "node scripts/multiplayer-e2e.mjs",
    "test:multiplayer:browser": "node scripts/multiplayer-browser-e2e.mjs",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "planck": "^1.4.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "puppeteer-core": "^25.3.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.26.0",
    "ws": "^8.21.1"
  }
}
